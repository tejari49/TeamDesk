rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
      return isSignedIn() && myUserDoc().role == 'admin';
    }

    function shareGroupWithMe(targetGroupIds) {
      return isSignedIn() && targetGroupIds.hasAny(myUserDoc().groupIds);
    }

    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids;
    }

    function withinOneHour(ts) {
      return request.time < ts + duration.value(1, 'h');
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isMasterAdmin() ||
        shareGroupWithMe(resource.data.groupIds)
      );
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isMasterAdmin());
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && (isMasterAdmin() || isGroupMember(groupId));
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isMasterAdmin() || isGroupAdmin(groupId);
      allow delete: if isMasterAdmin();
    }

    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        (request.resource.data.uid == request.auth.uid || isMasterAdmin());
      allow delete: if isMasterAdmin();
    }

    match /handovers/{handoverId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.createdByUid == request.auth.uid ||
        request.resource.data.createdByUid == request.auth.uid ||
        isMasterAdmin()
      );
      allow delete: if isMasterAdmin();
    }

    match /groupMessages/{messageId} {
      allow read: if isSignedIn() && isGroupMember(resource.data.groupId);
      allow create: if isSignedIn() &&
        isGroupMember(request.resource.data.groupId) &&
        request.resource.data.senderUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.senderUid == request.auth.uid &&
        withinOneHour(resource.data.createdAt);
      allow delete: if false;
    }

    match /directMessages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.senderUid == request.auth.uid &&
        withinOneHour(resource.data.createdAt);
      allow delete: if false;
    }


    match /release_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    match /links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
  }
}
