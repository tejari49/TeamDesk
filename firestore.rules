rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUids;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isMasterAdmin());
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isMasterAdmin() || isGroupAdmin(groupId);
      allow delete: if isMasterAdmin();
    }

    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        (request.resource.data.uid == request.auth.uid || isMasterAdmin());
      allow delete: if isMasterAdmin();
    }

    match /handovers/{handoverId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.createdByUid == request.auth.uid ||
        request.resource.data.createdByUid == request.auth.uid ||
        isMasterAdmin()
      );
      allow delete: if isMasterAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    match /links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
  }
}
